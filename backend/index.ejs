<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Traffic Dashboard</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background: #f4f4f4;
        }

        .car-dot{
 position:absolute;
 width:14px;
 height:14px;
 border-radius:50%;
 background:red;
}
        .dashboard {
            display: flex;
            flex-direction: row;
            height: 100vh;
        }
        .left-panel {
            width: 50%;
            padding: 32px 24px;
            background: #fff;
            box-shadow: 2px 0 8px #eee;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .right-panel {
            width: 50%;
            padding: 32px 24px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }
        .traffic-map {
            flex: 1;
            background: #e3e8f0;
            border-radius: 12px;
            position: relative;
            overflow: hidden;
        }
        .traffic-dot {
            position: absolute;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #e53e3e;
            opacity: 0.8;
            border: 2px solid #fff;
        }
        .section-title {
            font-size: 1.2em;
            font-weight: bold;
            margin-bottom: 8px;
        }
        .prediction-list {
            background: #fff;
            border-radius: 8px;
            padding: 16px;
            box-shadow: 0 2px 8px #eee;
        }
        select, button {
            padding: 8px 12px;
            font-size: 1em;
            border-radius: 4px;
            border: 1px solid #ccc;
        }
        .car-dot{
 position:absolute;
 width:14px;
 height:14px;
 border-radius:50%;
 background:red;
}
.dashboard-container{
    display:flex;
    gap:30px;
    padding:20px;
}

.left-panel{
    flex:2;
}

.right-panel{
    flex:1;
}

#vehicleMap{
    position:relative;
    height:350px;
    border:2px solid #ccc;
    background:#f9fafc;
    margin-top:10px;
}


    </style>
</head>
<body>
   <div class="dashboard-container">

    <!-- LEFT SIDE -->
    <div class="left-panel">
        <h2>Training Data</h2>
        <button onclick="createTrainingData()">Create Data</button>
        <button onclick="sendTrainingData()">Send Data</button>

        <div id="trainingDataPreview"></div>
    </div>


    <!-- RIGHT SIDE -->
    <div class="right-panel">
        <h2>Live Vehicle Locations</h2>

        <select id="placeSelect">
            <option value="">Select City</option>
            <option value="Delhi">Delhi</option>
            <option value="Mumbai">Mumbai</option>
            <option value="Bangalore">Bangalore</option>
            <option value="Chennai">Chennai</option>
            <option value="Kolkata">Kolkata</option>
        </select>

        <button onclick="fetchTrafficData()" >Get Live Data</button>

        <div id="vehicleMap" style="position:relative;height:350px;border:2px solid #ccc;background:#f9fafc;"></div>
    </div>


   <div style="display:flex; gap:20px; margin-top:20px;">

    <!-- Live Traffic Box -->
    <div style="width:50%; border:1px solid #ddd; padding:15px; border-radius:8px;">
        <h3>🚗 Live Traffic Map</h3>
        <div id="vehicleMap" style="height:250px; position:relative; background:#f7f7f7;"></div>
    </div>

    <!-- Prediction Box -->
<div style="width:50%; border:1px solid #ddd; padding:15px; border-radius:8px;">
<h3>🤖 Traffic Prediction</h3>

<button onclick="getPrediction()">Predict Traffic</button>

<div id="predictionMap" style="height:250px;position:relative;background:#f2f2f2"></div>

</div>

        <div id="predictionResult" style="margin-top:15px;"></div>
    </div>

</div>

</div>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    <script src="dashboard.js"></script>
    <script src="axios.min.js"></script>

</body>
</html>